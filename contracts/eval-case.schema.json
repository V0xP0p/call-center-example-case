{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/contracts/eval-case.schema.json",
  "title": "EvalCase",
  "type": "object",
  "required": ["scenario_id", "description", "input", "expected"],
  "properties": {
    "scenario_id": { "type": "string" },
    "description": { "type": "string" },
    "input": { "type": "object" },
    "expected": {
      "type": "object",
      "properties": {
        "route": { "type": "string" },
        "required_tools": { "type": "array", "items": { "type": "string" } },
        "required_docs": { "type": "array", "items": { "type": "string" } },
        "forbidden_docs": { "type": "array", "items": { "type": "string" } },
        "guardrail_expectation": { "type": "string" },
        "response_traits": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "scoring_dimensions": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}